	author        = {Mannochio-Russo, Helena and Ferreira, Patrick C. and Kvitne, Kine Eide and Patan, Abubaker and Deleray, Victoria and Agongo, Julius and Gouda, Harsha and Gon{\c c}alves Nunes, Wilhan D. and Xing, Shipei and Zemlin, Jasmine and van Faassen, Martijn and Reilly, Erin R. and Koo, Imhoi and Patterson, Andrew D. and Tsunoda, Shirley M. and Wang, Mingxun and Siegel, Dionicio and Burnett, Lindsey A. and Dorrestein, Pieter C.},
	title         = {Pan-Metabolomics Repository Mapping of the Carnitine Landscape},
